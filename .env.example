# AnchorPrune environment example (v0.9). Copy to .env and fill as needed.
# Provider API keys are read from the environment ONLY; never commit real keys.

# Optional real-provider keys (only needed for `real-eval --provider openai|anthropic`).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Logging (used by `serve` / `real-eval`).
ANCHORPRUNE_LOG_FORMAT=human   # human | json
ANCHORPRUNE_LOG_LEVEL=info     # debug | info | warning | error

# Dashboard -> API base URL (browser-side).
NEXT_PUBLIC_ANCHORPRUNE_API_URL=http://localhost:8000
